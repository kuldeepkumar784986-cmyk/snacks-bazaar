# ───────────────────────────────────────────────────
# Snack Bazaar — Backend Environment Variables
# ───────────────────────────────────────────────────
# 1. Rename this file to .env
# 2. Fill in your actual keys below
# ───────────────────────────────────────────────────

# Server
PORT=5001

# MongoDB — Get a free cluster at https://cloud.mongodb.com
# Click "Connect" → "Connect your application" → copy the URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/snackbazaar?retryWrites=true&w=majority

# Razorpay — Get test keys at https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Paytm (optional — uncomment the Paytm block in server.js to use)
# PAYTM_MID=
# PAYTM_MERCHANT_KEY=
# PAYTM_WEBSITE=WEBSTAGING
